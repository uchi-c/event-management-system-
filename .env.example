# Local SQLite database used by `node server.js` and `npm run dev`.
DATABASE_URL="file:./dev.db"

# Optional Supabase connection. When these are omitted, the app uses the local
# SQLite API first and falls back to browser localStorage if the API is offline.
# VITE_SUPABASE_URL="https://your-project.supabase.co"
# VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
